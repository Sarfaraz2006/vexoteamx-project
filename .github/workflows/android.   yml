   name: Build Android APK
    on:
      push:
        branches:
          - main
          - master
      workflow_dispatch: # Allows manual trigger from GitHub UI
    jobs:
      build-apk:
        runs-on: ubuntu-latest
        steps:
          - name: Checkout Source Code
            uses: actions/checkout@v4
          - name: Install Bun Runtime
            uses: oven-sh/setup-bun@v1
            with:
              bun-version: latest
          - name: Set up Java Development Kit (JDK 17)
            uses: actions/setup-java@v4
            with:
              distribution: 'zulu'
              java-version: '17'
              cache: 'gradle'
          - name: Set up Android SDK
            uses: android-actions/setup-android@v3
          - name: Install Node Dependencies
            run: |
              cd admin-app
              bun install
          - name: Compile Production Web Bundle
            run: |
              cd admin-app
              bun run build
          - name: Sync Capacitor Android Native Folder
            run: |
              cd admin-app
              bunx cap sync android
          - name: Build Android Debug APK with Gradle Wrapper
            run: |
              cd admin-app/android
              chmod +x gradlew
              ./gradlew assembleDebug
          - name: Upload Compile Artifact (Debug APK)
            uses: actions/upload-artifact@v4
            with:
              name: VexoteamX-Admin-App-APK
              path: admin-
  app/android/app/build/outputs/apk/debug/app-debug.apk
              retention-days: 14
